# Required for any live LLM run (free tier: https://aistudio.google.com).
GEMINI_API_KEY=AI...

# Optional — only needed for the Docker/AWS stack. For `uv run uvicorn` locally the
# defaults in app/config.py (SQLite + 127.0.0.1 sidecar) apply and these can stay unset.
# DATABASE_URL=postgresql+psycopg://kleinanzeigen:kleinanzeigen@db:5432/kleinanzeigen
# KLEINANZEIGEN_API_BASE_URL=http://sidecar:8000
